# Eureka — chế độ mặc định (gọi nội bộ Docker qua IP bridge 172.x)
EUREKA_INSTANCE_PREFER_IP_ADDRESS=true
# EUREKA_INSTANCE_IP_ADDRESS=
# EUREKA_EXTERNAL_HOST=

# Chế độ 2: Eureka hiển thị IP host (truy cập từ trình duyệt PC qua localhost:port)
# EUREKA_INSTANCE_PREFER_IP_ADDRESS=true
# EUREKA_INSTANCE_IP_ADDRESS=127.0.0.1

# Chế độ 3: hostname external (Docker Desktop)
# EUREKA_INSTANCE_PREFER_IP_ADDRESS=false
# EUREKA_EXTERNAL_HOST=host.docker.internal

# Mạng bridge — ưu tiên subnet Docker khi prefer-ip tự chọn IP
SPRING_CLOUD_INETUTILS_PREFERRED_NETWORKS=172.

MARIADB_ROOT_PASSWORD=123456a@A
